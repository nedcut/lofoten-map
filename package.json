{
  "name": "lofoten-logbook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "e2e:serve": "next build --webpack && next start",
    "ci": "npm run lint && npm run typecheck && npm run test",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:migrations": "supabase migration list --linked",
    "supabase:db:dry-run": "supabase db push --linked --dry-run",
    "supabase:db:push": "supabase db push --linked"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.107.0",
    "@turf/turf": "^7.3.5",
    "clsx": "^2.1.1",
    "exifreader": "^4.40.5",
    "lucide-react": "^1.17.0",
    "mapbox-gl": "^3.24.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mapbox-gl": "^3.5.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.8",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
